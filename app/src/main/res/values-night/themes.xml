<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AppTheme" parent="@android:style/Theme.Material">
        <item name="android:colorAccent">@color/blue_500</item>
        <item name="android:colorControlNormal">@color/blue_500</item>
        <item name="android:colorPrimaryDark">?android:colorPrimary</item>
        <item name="android:windowBackground">@color/content_background</item>
        <item name="android:popupMenuStyle">@style/AppTheme.PopupMenu</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="AppTheme.PopupMenu" parent="android:Widget.Material.PopupMenu">
        <item name="android:overlapAnchor">false</item>
        <item name="android:popupElevation">8dp</item>
        <item name="android:popupBackground">@drawable/popup_background</item>
        <item name="android:dropDownVerticalOffset">5dp</item>
    </style>
</resources>