<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" android:enterFadeDuration="30" android:exitFadeDuration="50">
    <item android:state_pressed="true">
        <shape android:shape="oval" android:useLevel="false" android:visible="true">
            <solid android:color="@android:color/white" />
            <size android:width="22dp" android:height="22dp" />
            <stroke android:width="7dp" android:color="@android:color/transparent" />
        </shape>
    </item>

    <item android:state_checked="true">
        <shape android:shape="oval" android:useLevel="false" android:visible="true">
            <solid android:color="@android:color/white" />
            <size android:width="22dp" android:height="22dp" />
            <stroke android:width="10dp" android:color="@android:color/transparent" />
        </shape>
    </item>

    <item android:state_checked="false">
        <shape android:shape="oval" android:useLevel="false" android:visible="true">
            <solid android:color="@android:color/white" />
            <size android:width="22dp" android:height="22dp" />
            <stroke android:width="10dp" android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>